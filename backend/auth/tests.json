{
  "tests": [
    {
      "name": "Register new user",
      "method": "POST",
      "path": "/?action=register",
      "body": {"name": "Тест Мама", "email": "testmama9991@mail.ru", "password": "secret123", "city": "Казань", "childAge": "3 мес"},
      "expectedStatus": 201,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login admin",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "admin@mamaclub.ru", "password": "admin123"},
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login wrong password",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "admin@mamaclub.ru", "password": "wrongpass"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Me without token",
      "method": "GET",
      "path": "/?action=me",
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}